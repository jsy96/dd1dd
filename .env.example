# 环境变量配置示例

# 飞书多维表格配置 - 用于获取HS编码
# 从飞书Base URL中提取ID，例如：
# URL: https://my.feishu.cn/base/OoNybRydGaN6Wwspy41cnQQCnGe?table=tbl2uWivrvboRe2a&view=vewu1hH18v
# FEISHU_BITABLE_ID=OoNybRydGaN6Wwspy41cnQQCnGe
# FEISHU_TABLE_ID=tbl2uWivrvboRe2a
# FEISHU_VIEW_ID=vewu1hH18v

FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_BITABLE_ID=your_bitable_id
FEISHU_TABLE_ID=your_table_id
FEISHU_VIEW_ID=your_view_id

# 注意事项：
# 1. 飞书应用需要开通"多维表格"权限
# 2. 多维表格需要包含"英文品名"和"HS编码"字段
# 3. 如果未配置飞书相关变量，系统将使用默认HS编码：88886666
