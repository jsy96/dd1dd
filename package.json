{
  "name": "manifest-processor",
  "version": "1.0.0",
  "description": "舱单文件处理系统 - 自动生成提单确认件和装箱单发票",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "electron:dev": "electron .",
    "electron:build": "electron-builder",
    "electron:build:win": "electron-builder --win --x64"
  },
  "dependencies": {
    "docxtemplater": "^3.68.3",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "pizzip": "^3.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.manifest.processor",
    "productName": "舱单文件处理系统",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,LICENSE,license}",
      "!**/node_modules/.bin",
      "!**/node_modules/*/test",
      "!**/node_modules/*/tests",
      "!**/node_modules/*/docs",
      "!**/{.git,.github,.gitignore,.DS_Store,*.log}",
      "!dist",
      "!src",
      "!scripts",
      "!assets",
      "!*.md",
      "!.next",
      "!.coze",
      "!.cozeproj"
    ],
    "extraResources": [
      {
        "from": "templates",
        "to": "templates",
        "filter": ["**/*"]
      },
      {
        "from": "public",
        "to": "public",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "舱单文件处理系统"
    }
  },
  "author": "Your Company",
  "license": "MIT",
  "private": true
}
